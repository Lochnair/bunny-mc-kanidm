#!/bin/sh
set -eu

: "${CADDY_LISTEN:=:8080}"
: "${CADDY_PUBLIC_HOST:=${KANIDM_DOMAIN:-idm.svee.eu}}"
: "${CADDY_UPSTREAM:=https://127.0.0.1:8443}"
: "${CADDY_HEALTH_PATH:=/healthz}"
: "${CADDY_HEALTH_RESPONSE:=ok}"
: "${CADDY_TLS_INSECURE_SKIP_VERIFY:=true}"
: "${CADDY_CONFIG_PATH:=/run/caddy/Caddyfile}"

is_true() {
  case "${1:-}" in
    true|TRUE|1|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

caddy_quote() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

mkdir -p "$(dirname "$CADDY_CONFIG_PATH")"

{
  printf '{\n'
  printf '\tadmin off\n'
  printf '\tauto_https off\n'
  printf '}\n'
  printf '\n'
  printf '%s {\n' "$CADDY_LISTEN"
  printf '\t@health path %s\n' "$CADDY_HEALTH_PATH"
  printf '\trespond @health "%s" 200\n' "$(caddy_quote "$CADDY_HEALTH_RESPONSE")"
  printf '\n'
  printf '\treverse_proxy %s {\n' "$CADDY_UPSTREAM"
  printf '\t\theader_up Host %s\n' "$CADDY_PUBLIC_HOST"
  printf '\t\theader_up X-Forwarded-Proto https\n'
  printf '\t\theader_up X-Forwarded-Host %s\n' "$CADDY_PUBLIC_HOST"
  printf '\n'
  printf '\t\ttransport http {\n'
  printf '\t\t\ttls_server_name %s\n' "$CADDY_PUBLIC_HOST"
  if is_true "$CADDY_TLS_INSECURE_SKIP_VERIFY"; then
    printf '\t\t\ttls_insecure_skip_verify\n'
  fi
  printf '\t\t}\n'
  printf '\t}\n'
  printf '}\n'
} > "$CADDY_CONFIG_PATH"
