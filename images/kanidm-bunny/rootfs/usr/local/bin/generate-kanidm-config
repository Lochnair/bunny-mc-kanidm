#!/bin/sh
set -eu

CONFIG_PATH="${CONFIG_PATH:-/data/server.toml}"
PEER_CERT_PATH="${PEER_CERT_PATH:-/data/replication-peer-cert.pem}"

# shellcheck source=images/kanidm-bunny/rootfs/usr/local/lib/kanidm-env-files.sh
. "${KANIDM_ENV_FILES_LIB:-/usr/local/lib/kanidm-env-files.sh}"

log() {
  printf '[kanidm-config] %s\n' "$*"
}

die() {
  printf '[kanidm-config] ERROR: %s\n' "$*" >&2
  exit 1
}

is_true() {
  case "${1:-}" in
    true|TRUE|1|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

env_is_set() {
  eval "[ \"\${$1+x}\" = x ]"
}

env_get() {
  eval "RESOLVED_VALUE=\${$1-}"
}

resolve_env() {
  base="$1"
  default="$2"
  secret="${3:-false}"

  for candidate in "${base}_${REGION_UPPER}" "${base}_${REGION_LOWER}" "$base"; do
    if env_is_set "$candidate"; then
      env_get "$candidate"
      if is_true "$secret"; then
        if [ -n "$RESOLVED_VALUE" ]; then
          log "${base}: selected ${candidate}; value present"
        else
          log "${base}: selected ${candidate}; value empty"
        fi
      else
        log "${base}: selected ${candidate}"
      fi
      return 0
    fi
  done

  RESOLVED_VALUE="$default"
  log "${base}: no region/global override selected; using default"
}

toml_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

tls_env_material_is_set() {
  env_is_set KANIDM_TLS_CHAIN_PEM \
    || env_is_set KANIDM_TLS_CHAIN_PEM_B64 \
    || env_is_set KANIDM_TLS_KEY_PEM \
    || env_is_set KANIDM_TLS_KEY_PEM_B64
}

require_nonempty() {
  name="$1"
  eval "value=\${$name:-}"
  [ -n "$value" ] || die "$name is required"
}

validate_client_address_mode() {
  name="$1"
  value="$2"
  allowed="$3"

  [ -z "$value" ] && return 0
  case " $allowed " in
    *" $value "*) ;;
    *) die "$name must be one of: $allowed" ;;
  esac
}

write_trusted_section() {
  section="$1"
  mode="$2"
  trusted="$3"

  [ -n "$mode" ] || return 0
  [ -n "$trusted" ] || die "${section} trusted addresses are required when mode is set"

  {
    printf '\n[%s]\n' "$section"
    printf '%s = [' "$mode"
    old_ifs="$IFS"
    IFS=,
    first=1
    for item in $trusted; do
      item=$(printf '%s' "$item" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
      [ -n "$item" ] || continue
      if [ "$first" -eq 0 ]; then
        printf ', '
      fi
      printf '"%s"' "$(toml_escape "$item")"
      first=0
    done
    IFS="$old_ifs"
    printf ']\n'
  } >> "$CONFIG_PATH"
}

trim_space() {
  printf '%s' "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

positive_integer() {
  case "$1" in
    ''|*[!0123456789]*) return 1 ;;
    *) [ "$1" -gt 0 ] ;;
  esac
}

nonnegative_integer() {
  case "$1" in
    ''|*[!0123456789]*) return 1 ;;
    *) return 0 ;;
  esac
}

require_openssl() {
  command -v openssl >/dev/null 2>&1 || die "openssl is required to generate or validate self-signed TLS material"
}

tls_cert_valid_beyond_threshold() {
  require_openssl
  threshold_seconds=$((KANIDM_TLS_SELF_SIGNED_REGENERATE_IF_EXPIRES_WITHIN_DAYS * 86400))
  openssl x509 -checkend "$threshold_seconds" -noout -in "$KANIDM_TLS_CHAIN" >/dev/null 2>&1
}

generate_self_signed_tls() {
  require_openssl

  dest_dir=$(dirname "$KANIDM_TLS_CHAIN")
  key_dir=$(dirname "$KANIDM_TLS_KEY")
  mkdir -p "$dest_dir" "$key_dir"

  chain_base=$(basename "$KANIDM_TLS_CHAIN")
  key_base=$(basename "$KANIDM_TLS_KEY")
  tmp_conf="${dest_dir}/.${chain_base}.openssl.$$"
  tmp_chain="${dest_dir}/.${chain_base}.tmp.$$"
  tmp_key="${key_dir}/.${key_base}.tmp.$$"
  rm -f "$tmp_conf" "$tmp_chain" "$tmp_key"

  san_count=0
  old_ifs="$IFS"
  IFS=,
  {
    printf '[req]\n'
    printf 'prompt = no\n'
    printf 'distinguished_name = dn\n'
    printf 'x509_extensions = v3_req\n'
    printf '\n[dn]\n'
    printf 'CN = %s\n' "$KANIDM_TLS_SELF_SIGNED_CN"
    printf '\n[v3_req]\n'
    printf 'basicConstraints = critical,CA:false\n'
    printf 'keyUsage = critical,digitalSignature,keyEncipherment\n'
    printf 'extendedKeyUsage = serverAuth\n'
    printf 'subjectAltName = @alt_names\n'
    printf '\n[alt_names]\n'
    for item in $KANIDM_TLS_SELF_SIGNED_SAN; do
      item=$(trim_space "$item")
      [ -n "$item" ] || continue
      san_count=$((san_count + 1))
      printf 'DNS.%s = %s\n' "$san_count" "$item"
    done
  } > "$tmp_conf"
  IFS="$old_ifs"

  if [ "$san_count" -eq 0 ]; then
    rm -f "$tmp_conf" "$tmp_chain" "$tmp_key"
    die "KANIDM_TLS_SELF_SIGNED_SAN must contain at least one DNS name"
  fi

  log "Generating self-signed TLS certificate at ${KANIDM_TLS_CHAIN} and key at ${KANIDM_TLS_KEY}"
  if [ "$KANIDM_TLS_SELF_SIGNED_KEY_TYPE" = rsa ]; then
    openssl req -x509 -newkey "rsa:${KANIDM_TLS_SELF_SIGNED_RSA_BITS}" -sha256 -nodes \
      -days "$KANIDM_TLS_SELF_SIGNED_DAYS" \
      -keyout "$tmp_key" \
      -out "$tmp_chain" \
      -config "$tmp_conf" >/dev/null 2>&1 \
      || { rm -f "$tmp_conf" "$tmp_chain" "$tmp_key"; die "Failed to generate RSA self-signed TLS material"; }
  else
    openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 -sha256 -nodes \
      -days "$KANIDM_TLS_SELF_SIGNED_DAYS" \
      -keyout "$tmp_key" \
      -out "$tmp_chain" \
      -config "$tmp_conf" >/dev/null 2>&1 \
      || { rm -f "$tmp_conf" "$tmp_chain" "$tmp_key"; die "Failed to generate EC self-signed TLS material"; }
  fi

  chmod 0644 "$tmp_chain" || { rm -f "$tmp_conf" "$tmp_chain" "$tmp_key"; die "Failed to chmod self-signed TLS chain temporary file"; }
  chmod 0600 "$tmp_key" || { rm -f "$tmp_conf" "$tmp_chain" "$tmp_key"; die "Failed to chmod self-signed TLS key temporary file"; }
  mv "$tmp_chain" "$KANIDM_TLS_CHAIN" || { rm -f "$tmp_conf" "$tmp_chain" "$tmp_key"; die "Failed to install self-signed TLS chain at ${KANIDM_TLS_CHAIN}"; }
  mv "$tmp_key" "$KANIDM_TLS_KEY" || { rm -f "$tmp_conf" "$tmp_key"; die "Failed to install self-signed TLS key at ${KANIDM_TLS_KEY}"; }
  rm -f "$tmp_conf"
}

provision_self_signed_tls_if_needed() {
  if ! is_true "$KANIDM_TLS_SELF_SIGNED_ENABLED"; then
    if [ ! -f "$KANIDM_TLS_CHAIN" ] || [ ! -f "$KANIDM_TLS_KEY" ]; then
      die "TLS files are missing and KANIDM_TLS_SELF_SIGNED_ENABLED is disabled"
    fi
    if ! tls_cert_valid_beyond_threshold; then
      die "TLS certificate is invalid, expired, or expiring within threshold and KANIDM_TLS_SELF_SIGNED_ENABLED is disabled"
    fi
    log "Self-signed TLS generation disabled; existing TLS files are present and valid"
    return 0
  fi

  if [ ! -f "$KANIDM_TLS_CHAIN" ]; then
    log "TLS chain file missing at ${KANIDM_TLS_CHAIN}; self-signed TLS generation required"
    generate_self_signed_tls
    return 0
  fi
  if [ ! -f "$KANIDM_TLS_KEY" ]; then
    log "TLS key file missing at ${KANIDM_TLS_KEY}; self-signed TLS generation required"
    generate_self_signed_tls
    return 0
  fi
  if tls_cert_valid_beyond_threshold; then
    log "Existing TLS certificate at ${KANIDM_TLS_CHAIN} is valid beyond threshold; reusing existing TLS files"
    return 0
  fi

  log "TLS certificate at ${KANIDM_TLS_CHAIN} is invalid, expired, or near expiry; regenerating self-signed TLS files"
  generate_self_signed_tls
}

: "${KANIDM_DOMAIN:=idm.svee.eu}"
: "${KANIDM_ORIGIN:=https://idm.svee.eu}"
: "${KANIDM_DB_PATH:=/data/kanidm.db}"
: "${KANIDM_TLS_CHAIN:=/data/chain.pem}"
: "${KANIDM_TLS_KEY:=/data/key.pem}"
: "${KANIDM_TLS_SELF_SIGNED_ENABLED:=true}"
: "${KANIDM_TLS_SELF_SIGNED_CN:=$KANIDM_DOMAIN}"
: "${KANIDM_TLS_SELF_SIGNED_SAN:=$KANIDM_TLS_SELF_SIGNED_CN}"
: "${KANIDM_TLS_SELF_SIGNED_DAYS:=3650}"
: "${KANIDM_TLS_SELF_SIGNED_REGENERATE_IF_EXPIRES_WITHIN_DAYS:=30}"
: "${KANIDM_TLS_SELF_SIGNED_KEY_TYPE:=ec}"
: "${KANIDM_TLS_SELF_SIGNED_RSA_BITS:=2048}"
: "${KANIDM_ONLINE_BACKUP_PATH:=/data/kanidm/backups/}"
: "${KANIDM_ONLINE_BACKUP_SCHEDULE:=00 22 * * *}"
: "${KANIDM_REPL_ENABLED:=false}"
: "${KANIDM_LDAP_ENABLED:=false}"
: "${KANIDM_HTTP_CLIENT_ADDRESS_INFO_MODE:=}"
: "${KANIDM_HTTP_CLIENT_ADDRESS_INFO_TRUSTED:=}"
: "${KANIDM_LDAP_CLIENT_ADDRESS_INFO_MODE:=}"
: "${KANIDM_LDAP_CLIENT_ADDRESS_INFO_TRUSTED:=}"

REGION_RAW="${BUNNYNET_MC_REGION:-unknown}"
REGION_LOWER="$(printf '%s' "$REGION_RAW" | tr '[:upper:]' '[:lower:]')"
REGION_UPPER="$(printf '%s' "$REGION_RAW" | tr '[:lower:]' '[:upper:]')"

resolve_env KANIDM_BINDADDRESS "0.0.0.0:8443"
KANIDM_BINDADDRESS="$RESOLVED_VALUE"
resolve_env KANIDM_LDAP_BINDADDRESS "127.0.0.1:3636"
KANIDM_LDAP_BINDADDRESS="$RESOLVED_VALUE"
resolve_env KANIDM_REPL_ORIGIN ""
KANIDM_REPL_ORIGIN="$RESOLVED_VALUE"
resolve_env KANIDM_REPL_BINDADDRESS "127.0.0.1:8444"
KANIDM_REPL_BINDADDRESS="$RESOLVED_VALUE"
resolve_env KANIDM_REPL_PEER_URL ""
KANIDM_REPL_PEER_URL="$RESOLVED_VALUE"
resolve_env KANIDM_REPL_PEER_CERT "" true
KANIDM_REPL_PEER_CERT="$RESOLVED_VALUE"
resolve_env KANIDM_REPL_PEER_CERT_B64 "" true
KANIDM_REPL_PEER_CERT_B64="$RESOLVED_VALUE"
resolve_env KANIDM_REPL_AUTOMATIC_REFRESH "false"
KANIDM_REPL_AUTOMATIC_REFRESH="$RESOLVED_VALUE"

if is_true "$KANIDM_REPL_ENABLED"; then
  require_nonempty KANIDM_REPL_ORIGIN
  if [ -n "$KANIDM_REPL_PEER_CERT" ] && [ -n "$KANIDM_REPL_PEER_CERT_B64" ]; then
    die "Set only one of KANIDM_REPL_PEER_CERT or KANIDM_REPL_PEER_CERT_B64"
  fi
  if [ -n "$KANIDM_REPL_PEER_URL" ] && [ -z "$KANIDM_REPL_PEER_CERT" ] && [ -z "$KANIDM_REPL_PEER_CERT_B64" ]; then
    die "KANIDM_REPL_PEER_CERT or KANIDM_REPL_PEER_CERT_B64 is required when KANIDM_REPL_PEER_URL is set"
  fi
  if [ -z "$KANIDM_REPL_PEER_URL" ] && { [ -n "$KANIDM_REPL_PEER_CERT" ] || [ -n "$KANIDM_REPL_PEER_CERT_B64" ]; }; then
    die "KANIDM_REPL_PEER_URL is required when a replication peer cert is set"
  fi
fi

validate_client_address_mode KANIDM_HTTP_CLIENT_ADDRESS_INFO_MODE "$KANIDM_HTTP_CLIENT_ADDRESS_INFO_MODE" "x-forward-for proxy-v2 proxy-v1"
validate_client_address_mode KANIDM_LDAP_CLIENT_ADDRESS_INFO_MODE "$KANIDM_LDAP_CLIENT_ADDRESS_INFO_MODE" "proxy-v2 proxy-v1"

positive_integer "$KANIDM_TLS_SELF_SIGNED_DAYS" || die "KANIDM_TLS_SELF_SIGNED_DAYS must be a positive integer"
nonnegative_integer "$KANIDM_TLS_SELF_SIGNED_REGENERATE_IF_EXPIRES_WITHIN_DAYS" || die "KANIDM_TLS_SELF_SIGNED_REGENERATE_IF_EXPIRES_WITHIN_DAYS must be a non-negative integer"
case "$KANIDM_TLS_SELF_SIGNED_KEY_TYPE" in
  ec|rsa) ;;
  *) die "KANIDM_TLS_SELF_SIGNED_KEY_TYPE must be one of: ec rsa" ;;
esac
positive_integer "$KANIDM_TLS_SELF_SIGNED_RSA_BITS" || die "KANIDM_TLS_SELF_SIGNED_RSA_BITS must be a positive integer"

tls_env_material_present=false
if tls_env_material_is_set; then
  tls_env_material_present=true
fi

write_env_file "TLS chain file" KANIDM_TLS_CHAIN_PEM KANIDM_TLS_CHAIN_PEM_B64 "$KANIDM_TLS_CHAIN" 0644
write_env_file "TLS key file" KANIDM_TLS_KEY_PEM KANIDM_TLS_KEY_PEM_B64 "$KANIDM_TLS_KEY" 0600
if [ "$tls_env_material_present" = true ]; then
  log "Explicit TLS environment material provided; self-signed TLS generation skipped"
else
  provision_self_signed_tls_if_needed
fi

log "Generating ${CONFIG_PATH} from environment"
log "region=${REGION_RAW}"
log "domain=${KANIDM_DOMAIN}"
log "origin=${KANIDM_ORIGIN}"
log "bindaddress=${KANIDM_BINDADDRESS}"
log "replication_enabled=${KANIDM_REPL_ENABLED}"
log "ldap_enabled=${KANIDM_LDAP_ENABLED}"

mkdir -p "$KANIDM_ONLINE_BACKUP_PATH"

umask 077
{
  printf 'version = "2"\n'
  printf 'bindaddress = "%s"\n' "$(toml_escape "$KANIDM_BINDADDRESS")"
  if is_true "$KANIDM_LDAP_ENABLED"; then
    printf 'ldapbindaddress = "%s"\n' "$(toml_escape "$KANIDM_LDAP_BINDADDRESS")"
  fi
  printf 'db_path = "%s"\n' "$(toml_escape "$KANIDM_DB_PATH")"
  printf 'tls_chain = "%s"\n' "$(toml_escape "$KANIDM_TLS_CHAIN")"
  printf 'tls_key = "%s"\n' "$(toml_escape "$KANIDM_TLS_KEY")"
  printf 'domain = "%s"\n' "$(toml_escape "$KANIDM_DOMAIN")"
  printf 'origin = "%s"\n' "$(toml_escape "$KANIDM_ORIGIN")"
  printf '\n[online_backup]\n'
  printf 'path = "%s"\n' "$(toml_escape "$KANIDM_ONLINE_BACKUP_PATH")"
  printf 'schedule = "%s"\n' "$(toml_escape "$KANIDM_ONLINE_BACKUP_SCHEDULE")"
} > "$CONFIG_PATH"

write_trusted_section "http_client_address_info" "$KANIDM_HTTP_CLIENT_ADDRESS_INFO_MODE" "$KANIDM_HTTP_CLIENT_ADDRESS_INFO_TRUSTED"
write_trusted_section "ldap_client_address_info" "$KANIDM_LDAP_CLIENT_ADDRESS_INFO_MODE" "$KANIDM_LDAP_CLIENT_ADDRESS_INFO_TRUSTED"

if is_true "$KANIDM_REPL_ENABLED"; then
  {
    printf '\n[replication]\n'
    printf 'origin = "%s"\n' "$(toml_escape "$KANIDM_REPL_ORIGIN")"
    printf 'bindaddress = "%s"\n' "$(toml_escape "$KANIDM_REPL_BINDADDRESS")"
  } >> "$CONFIG_PATH"

  if [ -n "$KANIDM_REPL_PEER_URL" ]; then
    if [ -n "$KANIDM_REPL_PEER_CERT_B64" ]; then
      if command -v base64 >/dev/null 2>&1; then
        printf '%s' "$KANIDM_REPL_PEER_CERT_B64" | base64 -d > "$PEER_CERT_PATH" || die "Failed to decode KANIDM_REPL_PEER_CERT_B64"
      else
        die "base64 command is required to decode KANIDM_REPL_PEER_CERT_B64"
      fi
      peer_cert=$(cat "$PEER_CERT_PATH")
    else
      peer_cert="$KANIDM_REPL_PEER_CERT"
    fi

    {
      printf '\n[replication."%s"]\n' "$(toml_escape "$KANIDM_REPL_PEER_URL")"
      printf 'type = "mutual-pull"\n'
      printf 'partner_cert = "%s"\n' "$(toml_escape "$peer_cert")"
      if is_true "$KANIDM_REPL_AUTOMATIC_REFRESH"; then
        printf 'automatic_refresh = true\n'
      fi
    } >> "$CONFIG_PATH"
  fi
fi

log "Generated ${CONFIG_PATH}; secret values were not logged"
