#!/bin/sh
set -eu

: "${OPS_BINDADDRESS:=127.0.0.1:9080}"
export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:-/lib}"
export PATH="${PATH:-/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin}"

printf '[kanidm-ops-api] Starting localhost ops API on %s\n' "$OPS_BINDADDRESS"
exec /usr/local/bin/kanidm-ops-api
